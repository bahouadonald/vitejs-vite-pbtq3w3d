{
  "id": "/",
  "name": "Doniel Zik",
  "short_name": "Doniel Zik",
  "description": "La première plateforme africaine de distribution musicale via QR Code. Écoutez, téléchargez et soutenez vos artistes préférés.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "window-controls-overlay", "tabbed", "minimal-ui"],
  "background_color": "#0E2A52",
  "theme_color": "#0E2A52",
  "orientation": "portrait",
  "lang": "fr",
  "dir": "ltr",
  "categories": ["music", "entertainment"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "note_taking": {
    "new_note_url": "/"
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "scope_extensions": [
    { "origin": "https://doniel.art" },
    { "origin": "https://doniel.vercel.app" }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "widgets": [
    {
      "name": "Doniel Zik",
      "description": "Écoutez votre musique africaine préférée",
      "tag": "doniel-zik-widget",
      "ms_ac_template": "widget/ac-template.json",
      "data": "widget/data.json",
      "type": "application/json",
      "screenshots": [{ "src": "/icons/screenshot1.png", "sizes": "720x304", "label": "Doniel Zik Widget" }],
      "icons": [{ "src": "/icons/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "protocol_handlers": [
    { "protocol": "web+donielzik", "url": "/?uri=%s" }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "audio/*": [".mp3", ".wav", ".aac", ".flac", ".m4a"],
        "video/*": [".mp4", ".mov", ".webm"]
      }
    }
  ],
  "icons": [
    { "src": "/icons/icon-72x72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128x128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-152x152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    { "src": "/icons/screenshot1.png", "type": "image/png", "form_factor": "narrow", "label": "Doniel Zik — FanPage" },
    { "src": "/icons/screenshot1.png", "type": "image/png", "form_factor": "wide", "label": "Doniel Zik — Découvrir" }
  ],
  "shortcuts": [
    { "name": "Découvrir", "short_name": "Découvrir", "url": "/decouvrir", "description": "Découvrez les artistes africains", "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }] },
    { "name": "Ma Zikothèque", "short_name": "Zikothèque", "url": "/ziko", "description": "Votre bibliothèque musicale", "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }] },
    { "name": "Recharger Oscart", "short_name": "Recharge", "url": "/ziko", "description": "Recharger vos Oscart", "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }] }
  ],
  "related_applications": [],
  "prefer_related_applications": false
}
